---
// src/components/Footer.astro
const YEAR = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">

    <!-- Top grid -->
    <div class="footer-grid">

      <!-- Brand col -->
      <div class="footer-brand">
        <a href="/" class="logo" aria-label="AI Tools Idea">
          <svg width="26" height="26" viewBox="0 0 28 28" fill="none">
            <rect width="28" height="28" rx="7" fill="#f59e0b"/>
            <path d="M7 14h4l2-6 4 12 2-6h2" stroke="#0a0e1a" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>AI Tools<strong>Idea</strong></span>
        </a>
        <p class="footer-tagline">
          Honest, in-depth reviews of AI tools for small business owners and freelancers. Updated weekly. No fluff.
        </p>
        <div class="footer-social">
          <a href="https://twitter.com/aitoolsidea" aria-label="Twitter/X" rel="noopener noreferrer" target="_blank">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://linkedin.com/company/aitoolsidea" aria-label="LinkedIn" rel="noopener noreferrer" target="_blank">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>

      <!-- Nav cols -->
      <div class="footer-col">
        <h4>Reviews</h4>
        <ul>
          <li><a href="/best-ai-tools">Best AI Tools 2025</a></li>
          <li><a href="/blog/zapier-alternatives">Zapier Alternatives</a></li>
          <li><a href="/blog/notion-alternatives">Notion Alternatives</a></li>
          <li><a href="/blog/best-free-crm">Best Free CRM</a></li>
          <li><a href="/blog/ai-writing-tools">AI Writing Tools</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Compare</h4>
        <ul>
          <li><a href="/blog/zapier-vs-make">Zapier vs Make</a></li>
          <li><a href="/blog/notion-vs-clickup">Notion vs ClickUp</a></li>
          <li><a href="/blog/clickup-vs-asana">ClickUp vs Asana</a></li>
          <li><a href="/blog/calendly-vs-acuity">Calendly vs Acuity</a></li>
          <li><a href="/compare">All comparisons →</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Company</h4>
        <ul>
          <li><a href="/about">About</a></li>
          <li><a href="/newsletter">Newsletter</a></li>
          <li><a href="/contact">Contact</a></li>
          <li><a href="/legal/affiliate-disclosure">Affiliate Disclosure</a></li>
          <li><a href="/legal/privacy-policy">Privacy Policy</a></li>
          <li><a href="/legal/terms-of-service">Terms of Service</a></li>
        </ul>
      </div>

    </div>

    <!-- Divider -->
    <div class="footer-divider"></div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p class="footer-copy">
        © {YEAR} AI Tools Idea. All rights reserved.
      </p>
      <div class="footer-legal-links">
        <a href="/legal/privacy-policy">Privacy</a>
        <span aria-hidden="true">·</span>
        <a href="/legal/terms-of-service">Terms</a>
        <span aria-hidden="true">·</span>
        <a href="/legal/affiliate-disclosure">Affiliates</a>
        <span aria-hidden="true">·</span>
        <a href="/legal/cookie-policy">Cookies</a>
      </div>
      <p class="footer-disclaimer">
        We earn commissions from affiliate links at no cost to you.
      </p>
    </div>

  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--c-border);
    padding: var(--space-16) 0 var(--space-8);
    margin-top: var(--space-20);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-10);
    margin-bottom: var(--space-12);
  }

  /* Brand */
  .footer-brand .logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--c-white);
  }
  .footer-brand .logo strong { color: var(--c-amber); }
  .footer-tagline {
    font-size: 0.875rem;
    color: var(--c-text-3);
    line-height: 1.6;
    margin-bottom: var(--space-5);
    max-width: 280px;
  }
  .footer-social {
    display: flex;
    gap: var(--space-3);
  }
  .footer-social a {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--c-text-3);
    transition: all var(--dur-fast);
  }
  .footer-social a:hover {
    color: var(--c-amber);
    border-color: var(--c-amber-glow);
    background: var(--c-amber-dim);
  }

  /* Nav cols */
  .footer-col h4 {
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-text-3);
    margin-bottom: var(--space-4);
  }
  .footer-col ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .footer-col a {
    font-size: 0.875rem;
    color: var(--c-text-2);
    transition: color var(--dur-fast);
  }
  .footer-col a:hover { color: var(--c-amber); }

  /* Divider */
  .footer-divider {
    height: 1px;
    background: var(--c-border);
    margin-bottom: var(--space-6);
  }

  /* Bottom */
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
  }
  .footer-copy, .footer-disclaimer {
    font-size: 0.8rem;
    color: var(--c-text-3);
  }
  .footer-legal-links {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: 0.8rem;
  }
  .footer-legal-links a {
    color: var(--c-text-3);
    transition: color var(--dur-fast);
  }
  .footer-legal-links a:hover { color: var(--c-amber); }
  .footer-legal-links span { color: var(--c-border-mid); }

  @media (max-width: 900px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: var(--space-8); }
    .footer-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 540px) {
    .footer-grid { grid-template-columns: 1fr; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
  }
</style>
