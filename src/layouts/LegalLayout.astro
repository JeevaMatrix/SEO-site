---
// src/layouts/LegalLayout.astro
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  lastUpdated: string;
}
const { title, description, lastUpdated } = Astro.props;
---

<BaseLayout title={title} description={description} noindex={true}>
  <div class="legal-page">
    <div class="legal-header">
      <div class="container container--prose">
        <a href="/" class="legal-back">← Back to AI Tools Idea</a>
        <div class="badge badge--ghost" style="margin:1rem 0">Legal</div>
        <h1>{title}</h1>
        <p class="legal-updated">Last updated: {lastUpdated}</p>
      </div>
    </div>
    <div class="container container--prose legal-body">
      <div class="prose">
        <slot />
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .legal-page { padding-bottom: var(--space-20); }
  .legal-header {
    background: var(--c-bg2);
    border-bottom: 1px solid var(--c-border);
    padding: var(--space-10) 0 var(--space-8);
    margin-bottom: var(--space-10);
  }
  .legal-back {
    font-size: 0.85rem;
    color: var(--c-text-3);
    display: inline-block;
    margin-bottom: var(--space-4);
    transition: color var(--dur-fast);
  }
  .legal-back:hover { color: var(--c-amber); }
  .legal-header h1 { font-size: 2rem; margin-bottom: var(--space-2); }
  .legal-updated { font-size: 0.85rem; color: var(--c-text-3); }
  .legal-body { }
</style>
