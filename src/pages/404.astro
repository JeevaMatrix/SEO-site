---
// src/pages/404.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found — AI Tools Idea"
  description="This page doesn't exist. Browse our AI tool reviews instead."
  noindex={true}
>
  <div class="error-page">
    <div class="container">
      <div class="error-inner">
        <div class="error-code" aria-hidden="true">404</div>
        <h1>Page not found</h1>
        <p>This page doesn't exist or has been moved. Try browsing our reviews instead.</p>
        <div class="error-actions">
          <a href="/" class="btn btn--primary">← Back to home</a>
          <a href="/blog" class="btn btn--ghost">Browse all reviews</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .error-page {
    min-height: 70vh;
    display: flex;
    align-items: center;
  }
  .error-inner {
    text-align: center;
    max-width: 480px;
    margin: 0 auto;
    padding: var(--space-16) 0;
  }
  .error-code {
    font-family: var(--font-display);
    font-size: 7rem;
    font-weight: 800;
    color: var(--c-amber);
    opacity: 0.15;
    line-height: 1;
    margin-bottom: var(--space-4);
    letter-spacing: -0.05em;
  }
  .error-inner h1 { font-size: 2rem; margin-bottom: var(--space-3); }
  .error-inner p  { color: var(--c-text-2); margin-bottom: var(--space-8); }
  .error-actions  { display: flex; gap: var(--space-3); justify-content: center; flex-wrap: wrap; }
</style>
