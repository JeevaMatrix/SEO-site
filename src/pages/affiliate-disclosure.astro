---
// src/pages/affiliate-disclosure.astro
// Required by FTC and all affiliate networks.
// Without this you can be removed from affiliate programs.
const SITE_NAME = import.meta.env.SITE_NAME || 'AI Tools Guide';
const SITE_URL = import.meta.env.SITE_URL || 'https://yoursite.com';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Affiliate Disclosure | {SITE_NAME}</title>
  <meta name="robots" content="noindex" />
  <style>
    body { font-family: system-ui, sans-serif; max-width: 700px; margin: 3rem auto; padding: 0 1.5rem; line-height: 1.7; color: #1a1a1a; }
    h1 { font-size: 1.75rem; margin-bottom: 1rem; }
    h2 { font-size: 1.2rem; margin: 2rem 0 0.5rem; }
    a { color: #0f6e56; }
  </style>
</head>
<body>
  <h1>Affiliate Disclosure</h1>
  <p>Last updated: {new Date().toLocaleDateString('en-US', {month:'long', day:'numeric', year:'numeric'})}</p>

  <h2>What this means</h2>
  <p>
    {SITE_NAME} participates in affiliate marketing programs. This means we may earn a
    commission when you click links on our site and make a purchase or sign up for a service —
    at no additional cost to you.
  </p>

  <h2>Which programs we participate in</h2>
  <p>We are affiliates of programs including but not limited to:</p>
  <ul>
    <li>Amazon Associates</li>
    <li>PartnerStack (Notion, ClickUp, and other SaaS tools)</li>
    <li>ShareASale</li>
    <li>Impact.com</li>
  </ul>

  <h2>Our editorial independence</h2>
  <p>
    Affiliate relationships do not influence our editorial content. We recommend tools
    based on research and usefulness to small business owners, not commission rates.
    We disclose affiliate relationships clearly on every article that contains affiliate links.
  </p>

  <h2>FTC compliance</h2>
  <p>
    This disclosure is made in accordance with the Federal Trade Commission's 16 CFR Part 255:
    "Guides Concerning the Use of Endorsements and Testimonials in Advertising."
  </p>

  <p><a href="/">← Back to home</a></p>
</body>
</html>
